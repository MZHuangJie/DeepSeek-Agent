{
  "name": "deepseek-agent",
  "version": "1.0.0",
  "description": "DeepSeek Agent Desktop IDE",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.ts && node scripts/fix-electron-build.js",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "start:server": "tsx server/index.ts",
    "dev:server": "tsx watch server/index.ts",
    "dev": "node scripts/dev.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/setup-monaco.js"
  },
  "build": {
    "appId": "com.deepseek.agent",
    "productName": "DeepSeek Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!**/*.map",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.map",
      "!node_modules/**/docs",
      "!node_modules/**/test",
      "!node_modules/**/tests",
      "!node_modules/**/example",
      "!node_modules/**/examples",
      "!node_modules/**/benchmark",
      "!node_modules/.bin",
      "!node_modules/electron/**",
      "!node_modules/app-builder-bin/**",
      "!node_modules/electron-winstaller/**",
      "!node_modules/typescript/**",
      "!node_modules/@esbuild/**",
      "!node_modules/7zip-bin/**",
      "!node_modules/monaco-editor/dev/**",
      "!node_modules/monaco-editor/esm/**",
      "!node_modules/node-pty/build/**"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "public/assets/logo.png"
    },
    "publish": null,
    "compression": "maximum",
    "npmRebuild": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "keywords": [
    "electron",
    "deepseek",
    "agent",
    "ide"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "glob": "^11.0.1",
    "jsonwebtoken": "^9.0.2",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.0.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.3"
  }
}
