{
  "name": "deepseek-agent-server",
  "version": "1.0.0",
  "description": "DeepSeek Agent 云端同步服务端",
  "type": "module",
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "tsx watch server/index.ts",
    "build": "tsc --outDir dist --esModuleInterop --target es2022 --skipLibCheck --moduleResolution node --module commonjs server/**/*.ts",
    "serve": "node dist/server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
